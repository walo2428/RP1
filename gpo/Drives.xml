                userName="" path="\\SRV-DC01\SLAM"
                label="SLAM" persistent="1" useLetter="1" letter="S"/>
    <Filters>
      <FilterGroup bool="AND" not="0" name="IRIS\GRP-Etudiants-SLAM"
